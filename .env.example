FLASK_APP=run.py
FLASK_DEBUG=1
SECRET_KEY=change-this-secret
DATABASE_URL=sqlite:///expense_lending.db

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
MAIL_FROM=your-email@gmail.com
SMTP_USE_TLS=1
SMTP_USE_SSL=0

# Scheduler checks overdue records every N hours.
REMINDER_INTERVAL_HOURS=1

# Keep local scheduler on for local development.
# In production with a Cron Job, set ENABLE_SCHEDULER=0.
ENABLE_SCHEDULER=1
